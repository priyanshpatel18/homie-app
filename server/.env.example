# Homie Server — required environment variables
# Copy this file to .env and fill in your values.

# OpenRouter (LLM provider) — https://openrouter.ai/keys
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-...
LLM_MODEL=openai/gpt-4o-mini

# Jupiter API key (optional — improves rate limits) — https://portal.jup.ag
JUP_API_KEY=jup_...

# Birdeye API key (optional — improves token data) — https://birdeye.so/developer
BIRDEYE_API_KEY=...

# Sanctum API key (optional — required for production swap volume) — https://sanctum.so
SANCTUM_API_KEY=...

# Jito Block Engine URL (optional — defaults to mainnet)
# JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

# Port (default: 3000)
# PORT=3000
