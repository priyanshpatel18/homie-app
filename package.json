{
  "name": "homie-app",
  "private": true,
  "scripts": {
    "frontend:dev": "pnpm --filter frontend dev",
    "frontend:build": "pnpm --filter frontend build",
    "frontend:lint": "pnpm --filter frontend lint",
    "frontend:start": "pnpm --filter frontend start",
    "mobile:dev": "pnpm --filter mobile start",
    "mobile:start": "pnpm --filter mobile start",
    "mobile:android": "pnpm --filter mobile android",
    "mobile:ios": "pnpm --filter mobile ios",
    "mobile:web": "pnpm --filter mobile web",
    "server:dev": "pnpm --filter server dev",
    "server:start": "pnpm --filter server start",
    "sdk:build": "pnpm --filter @homie/sdk build",
    "sdk:dev": "pnpm --filter @homie/sdk dev",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
