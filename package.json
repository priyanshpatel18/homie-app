{
  "name": "homie-app",
  "private": true,
  "workspaces": [
    "frontend",
    "server",
    "packages/*",
    "sdk/*"
  ],
  "scripts": {
    "frontend:dev": "npm run dev -w frontend",
    "frontend:build": "npm run build -w frontend",
    "frontend:lint": "npm run lint -w frontend",
    "frontend:start": "npm run start -w frontend",
    "mobile:install": "npm install --prefix mobile",
    "mobile:dev": "npm start --prefix mobile",
    "mobile:start": "npm start --prefix mobile",
    "mobile:android": "npm run android --prefix mobile",
    "mobile:ios": "npm run ios --prefix mobile",
    "mobile:web": "npm run web --prefix mobile",
    "server:dev": "npm run dev -w server",
    "server:start": "npm run start -w server",
    "sdk:build": "npm run build -w @homie/sdk",
    "sdk:dev": "npm run dev -w @homie/sdk",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=10"
  }
}
